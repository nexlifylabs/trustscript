#. Description of the plugin
#: trustscript.php
msgid ""
"Automated review collection for WooCommerce — verified, visual, AI-assisted,"
" and 100% privacy compliant. No PII. No manual work."
msgstr ""
"Raccolta automatizzata delle recensioni per WooCommerce: verificata, visiva,"
" assistita dall'intelligenza artificiale e conforme al 100% alle norme sulla"
" privacy. Nessun dato personale. Nessun intervento manuale."

