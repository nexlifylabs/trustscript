msgid "2 weeks"
msgstr "2 weken"

#: includes/admin/review-setting.php:223 includes/admin/review-setting.php:260
msgid "3 weeks"
msgstr "3 weken"

#: includes/admin/review-setting.php:224 includes/admin/review-setting.php:261
msgid "4 weeks (1 month)"
msgstr "4 weken (1 maand)"

#: includes/admin/review-setting.php:225 includes/admin/review-setting.php:263
msgid "Custom..."
msgstr "Op maat..."

