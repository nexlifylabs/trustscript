msgstr "अंतिम रन: संसाधित"

#: includes/admin/review-setting.php:486
msgid "Last Run: Skipped"
msgstr "पिछली बार: छोड़ा गया"

#: includes/admin/review-setting.php:490
msgid "Last Run: Errors"
msgstr "अंतिम रन: त्रुटियाँ"

#: includes/admin/review-setting.php:494
msgid "Last run:"
msgstr "अंतिम दौड़:"

#: includes/admin/review-setting.php:502
#: includes/class-trustscript-admin.php:682
msgid "Save Review Settings"
msgstr "समीक्षा सेटिंग्स सहेजें"

#: includes/admin/review-setting.php:510
msgid "Manual Sync & Test"
msgstr "मैनुअल सिंक और परीक्षण"

#: includes/admin/review-setting.php:513
msgid ""
"Run a complete sync immediately without waiting for the daily schedule. This"
" is helpful for testing on staging sites."
msgstr ""
"दैनिक अनुसूची की प्रतीक्षा किए बिना तुरंत एक पूर्ण सिंक चलाएँ। यह स्टेजिंग "
