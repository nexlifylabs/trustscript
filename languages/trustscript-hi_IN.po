msgstr "श्रेणियाँ खोजें..."

#: includes/class-trustscript-admin.php:1673
#: includes/consent/privacy-settings.php:249
msgid "Select All"
msgstr "सभी चुनें"

#: includes/class-trustscript-admin.php:1677
#: includes/consent/privacy-settings.php:252
msgid "Deselect All"
msgstr "सभी को असूचीबद्ध करें"

#: includes/class-trustscript-admin.php:1691
msgid "No product categories found."
msgstr "कोई उत्पाद श्रेणियाँ नहीं मिलीं।"

#: includes/class-trustscript-admin.php:1695
msgid "Order Value Filtering"
msgstr "ऑर्डर मूल्य फ़िल्टरिंग"

#. translators: %s: store currency symbol
#: includes/class-trustscript-admin.php:1701
#, php-format
msgid "Minimum Order Value (%s):"
msgstr "न्यूनतम ऑर्डर मूल्य (%s):"

#: includes/class-trustscript-admin.php:1708
msgid ""
